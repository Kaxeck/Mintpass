    "@metaplex-foundation/umi-web3js-adapters": "^1.5.1",
    "@solana/actions": "^1.6.6",
    "@solana/client": "^1.2.0",
    "@solana/kit": "^5.1.0",
    "@solana/react-hooks": "^1.1.5",
    "@solana/wallet-adapter-react": "^0.15.39",
